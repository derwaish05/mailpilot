/**
 * Small reusable primitives: Switch, Segmented control, resizable gutter,
 * icon chip, and a click-outside hook used by menus/popovers.
 */
import { useEffect, useRef } from '@wordpress/element';

export function useClickOutside( ref, onOutside, active = true ) {
	useEffect( () => {
		if ( ! active ) return undefined;
		function handle( e ) {
			if ( ref.current && ! ref.current.contains( e.target ) ) {
				onOutside();
			}
		}
		function handleEsc( e ) {
			if ( e.key === 'Escape' ) onOutside();
		}
		document.addEventListener( 'mousedown', handle );
		document.addEventListener( 'keydown', handleEsc );
		return () => {
			document.removeEventListener( 'mousedown', handle );
			document.removeEventListener( 'keydown', handleEsc );
		};
	}, [ ref, onOutside, active ] );
}

export function Switch( { checked, onChange, label } ) {
	return (
		<button
			type="button"
			role="switch"
			aria-checked={ checked }
			aria-label={ label }
			className={ `fb-switch${ checked ? ' is-on' : '' }` }
			onClick={ () => onChange( ! checked ) }
		>
			<span className="fb-switch-knob" />
		</button>
	);
}

export function Segmented( { options, value, onChange, purple = false, ariaLabel } ) {
	return (
		<div role="group" aria-label={ ariaLabel } className={ `fb-segmented${ purple ? ' is-purple' : '' }` }>
			{ options.map( ( o ) => (
				<button
					key={ o.value }
					type="button"
					className={ `fb-segmented-option${ value === o.value ? ' is-active' : '' }` }
					onClick={ () => onChange( o.value ) }
				>
					{ o.icon ? <o.icon size={ 14 } /> : null }
					{ o.label }
				</button>
			) ) }
		</div>
	);
}

export function IconChip( { icon: Icon, bg, fg, size = 28, iconSize = 14 } ) {
	return (
		<span className="fb-icon-chip" style={ { width: size, height: size, background: bg, color: fg } }>
			<Icon size={ iconSize } strokeWidth={ 2 } />
		</span>
	);
}

export function ResizeHandle( { onResizeStart, label } ) {
	const activeRef = useRef( false );
	return (
		<div
			role="separator"
			aria-orientation="vertical"
			aria-label={ label }
			className="fb-resize-handle"
			onPointerDown={ ( e ) => {
				activeRef.current = true;
				onResizeStart( e );
			} }
		>
			<div className="fb-resize-grip" />
		</div>
	);
}
