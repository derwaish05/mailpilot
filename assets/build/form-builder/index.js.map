/**
 * Form Builder app shell: owns the reducer store, the pointer-based
 * drag-and-drop controller (library → canvas insert, grip → canvas
 * reorder), resizable side panels, keyboard shortcuts, autosave, and wires
 * up the four regions (Toolbar / Field Library / Canvas / Properties).
 */
import { useReducer, useEffect, useRef, useCallback, useState } from '@wordpress/element';
import Toolbar from './components/Toolbar';
import FieldLibrary from './components/FieldLibrary';
import Canvas from './components/Canvas';
import PropertiesPanel from './components/PropertiesPanel';
import PreviewModal from './components/PreviewModal';
import Toast from './components/Toast';
import { reducer, initialState } from './state';
import { fetchForm, saveForm, config } from './api';
import { toApiField, clamp, debounce } from './utils';

const LEFT_MIN = 220;
const LEFT_MAX = 340;
const LEFT_DEFAULT = 272;
const RIGHT_MIN = 280;
const RIGHT_MAX = 420;
const RIGHT_DEFAULT = 336;

function formatSavedLabel( ts ) {
	if ( ! ts ) return 'Saved';
	const diff = Math.round( ( Date.now() - ts ) / 1000 );
	if ( diff < 5 ) return 'Saved just now';
	if ( diff < 60 ) return `Saved ${ diff }s ago`;
	const mins = Math.round( diff / 60 );
	return `Saved ${ mins }m ago`;
}

export default function App() {
	const [ state, dispatch ] = useReducer( reducer, undefined, initialState );
	const stateRef = useRef( state );
	stateRef.current = state;

	const [ leftWidth, setLeftWidth ] = useState( LEFT_DEFAULT );
	const [ rightWidth, setRightWidth ] = useState( RIGHT_DEFAULT );

	const canvasRef = useRef( null );
	const cardsRef = useRef( null );
	const dragMeta = useRef( { active: false, started: false, kind: null, payload: null, startX: 0, startY: 0, ghost: null } );
	const [ dragState, setDragState ] = useState( null );

	const fieldTypes = config.fieldTypes || [];
	const displayTypes = config.displayTypes || [];
	const providers = config.providers || [];

	/* ─── Load / new form ─── */
	useEffect( () => {
		if ( config.formId && config.formId > 0 ) {
			fetchForm( config.formId )
				.then( ( data ) => dispatch( { type: 'LOAD', payload: data } ) )
				.catch( () => dispatch( { type: 'NEW_FORM_READY' } ) );
		} else {
			dispatch( { type: 'NEW_FORM_READY' } );
		}
		// eslint-disable-next-line react-hooks/exhaustive-deps
	}, [] );

	/* ─── Save ─── */
	const doSave = useCallback( () => {
		const s = stateRef.current;
		dispatch( { type: 'SET_SAVE_STATE', value: 'saving' } );
		const payload = {
			title: s.title,
			status: s.status,
			display_type: s.display_type,
			fields: s.fields.map( toApiField ),
			actions: s.actions,
			settings: s.settings,
		};
		return saveForm( s.id, payload )
			.then( ( data ) => {
				dispatch( { type: 'MARK_SAVED', id: data.id, shortcode: data.shortcode } );
				if ( ( ! s.id || s.id === 0 ) && data.id ) {
					const url = `${ config.editUrlBase }&form=${ data.id }`;
					window.history.replaceState( null, '', url );
				}
				dispatch( { type: 'SHOW_TOAST', message: 'Form saved' } );
				return data;
			} )
			.catch( () => {
				dispatch( { type: 'SET_SAVE_STATE', value: 'dirty' } );
				dispatch( { type: 'SHOW_TOAST', message: 'Save failed — try again' } );
			} );
	}, [] );

	/* Toast auto-dismiss */
	useEffect( () => {
		if ( ! state.ui.toast ) return undefined;
		const t = setTimeout( () => dispatch( { type: 'HIDE_TOAST' } ), 2000 );
		return () => clearTimeout( t );
	}, [ state.ui.toast ] );

	/* Autosave: debounce 1.5s after a dirty change once the form is loaded and has an id (avoid autosaving brand-new unsaved forms before first manual save is a fine simplification, but we still autosave once it has an id). */
	const debouncedSave = useRef( debounce( () => doSave(), 1500 ) ).current;
	useEffect( () => {
		if ( ! state.loaded ) return;
		if ( state.ui.saveState === 'dirty' ) {
			debouncedSave();
		}
	}, [ state, debouncedSave ] );

	/* ─── Keyboard shortcuts ─── */
	useEffect( () => {
		function onKeyDown( e ) {
			const mod = e.metaKey || e.ctrlKey;
			const tag = ( e.target.tagName || '' ).toLowerCase();
			const typing = tag === 'input' || tag === 'textarea' || tag === 'select' || e.target.isContentEditable;

			if ( mod && ! e.shiftKey && e.key.toLowerCase() === 'z' ) {
				e.preventDefault();
				dispatch( { type: 'UNDO' } );
				return;
			}
			if ( mod && e.shiftKey && e.key.toLowerCase() === 'z' ) {
				e.preventDefault();
				dispatch( { type: 'REDO' } );
				return;
			}
			if ( mod && e.key.toLowerCase() === 's' ) {
				e.preventDefault();
				doSave();
				return;
			}
			if ( e.key === 'Delete' || e.key === 'Backspace' ) {
				if ( ! typing && stateRef.current.ui.selectedId ) {
					e.preventDefault();
					dispatch( { type: 'DELETE_FIELD', id: stateRef.current.ui.selectedId } );
				}
				return;
			}
			if ( e.key === 'Escape' ) {
				dispatch( { type: 'CLOSE_MENUS' } );
				dispatch( { type: 'CLOSE_PREVIEW' } );
			}
		}
		window.addEventListener( 'keydown', onKeyDown );
		return () => window.removeEventListener( 'keydown', onKeyDown );
	}, [ doSave ] );

	/* Warn on unload if dirty */
	useEffect( () => {
		function onBeforeUnload( e ) {
			if ( stateRef.current.ui.saveState !== 'saved' ) {
				e.preventDefault();
				e.returnValue = '';
			}
		}
		window.addEventListener( 'beforeunload', onBeforeUnload );
		return () => window.removeEventListener( 'beforeunload', onBeforeUnload );
	}, [] );

	/* ─── Drag & drop ─── */
	const computeDropIndex = useCallback( ( clientY ) => {
		const container = cardsRef.current;
		if ( ! container ) return 0;
		const cards = Array.from( container.querySelectorAll( '.fb-field-card' ) );
		for ( let i = 0; i < cards.length; i++ ) {
			const rect = cards[ i ].getBoundingClientRect();
			if ( clientY < rect.top + rect.height / 2 ) return i;
		}
		return cards.length;
	}, [] );

	const autoScroll = useCallback( ( clientY ) => {
		const el = canvasRef.current;
		if ( ! el ) return;
		const rect = el.getBoundingClientRect();
		if ( clientY - rect.top < 60 ) el.scrollTop -= 12;
		else if ( rect.bottom - clientY < 60 ) el.scrollTop += 12;
	}, [] );

	const handleMove = useCallback(
		( e ) => {
			const m = dragMeta.current;
			if ( ! m.active ) return;
			const dx = e.clientX - m.startX;
			const dy = e.clientY - m.startY;
			if ( ! m.started ) {
				if ( Math.hypot( dx, dy ) < 5 ) return;
				m.started = true;
			}
			const dropIndex = computeDropIndex( e.clientY );
			setDragState( { kind: m.kind, data: m.payload, started: true, dropIndex, x: e.clientX, y: e.clientY, ghost: m.ghost } );
			autoScroll( e.clientY );
		},
		[ computeDropIndex, autoScroll ]
	);

	const handleUp = useCallback(
		( e ) => {
			const m = dragMeta.current;
			window.removeEventListener( 'pointermove', handleMove );
			if ( ! m.active ) return;
			m.active = false;

			if ( m.started ) {
				const dropIndex = computeDropIndex( e.clientY );
				if ( m.kind === 'library' ) {
					dispatch( { type: 'ADD_FIELD', typeDescriptor: m.payload.typeDescriptor, index: dropIndex } );
					dispatch( { type: 'ADD_RECENT', fieldType: m.payload.typeDescriptor.type } );
				} else if ( m.kind === 'reorder' ) {
					dispatch( { type: 'MOVE_FIELD', from: m.payload.fromIndex, to: dropIndex } );
				}
			} else if ( m.kind === 'library' ) {
				dispatch( { type: 'ADD_FIELD', typeDescriptor: m.payload.typeDescriptor, index: stateRef.current.fields.length } );
				dispatch( { type: 'ADD_RECENT', fieldType: m.payload.typeDescriptor.type } );
			}
			setDragState( null );
		},
		[ handleMove, computeDropIndex ]
	);

	const startDrag = useCallback(
		( e, kind, payload, ghost ) => {
			if ( e.button !== undefined && e.button !== 0 ) return;
			dragMeta.current = { active: true, started: false, kind, payload, startX: e.clientX, startY: e.clientY, ghost };
			window.addEventListener( 'pointermove', handleMove );
			window.addEventListener( 'pointerup', handleUp, { once: true } );
		},
		[ handleMove, handleUp ]
	);

	const onItemPointerDown = useCallback(
		( e, descriptor ) => startDrag( e, 'library', { typeDescriptor: descriptor }, { label: descriptor.label, type: descriptor.type } ),
		[ startDrag ]
	);
	const onQuickAdd = useCallback( ( descriptor ) => {
		dispatch( { type: 'ADD_FIELD', typeDescriptor: descriptor, index: stateRef.current.fields.length } );
		dispatch( { type: 'ADD_RECENT', fieldType: descriptor.type } );
	}, [] );
	const onGripPointerDown = useCallback(
		( e, fieldId, index ) => startDrag( e, 'reorder', { fieldId, fromIndex: index } ),
		[ startDrag ]
	);
	const onAddFirstField = useCallback( () => {
		const first = fieldTypes[ 0 ];
		if ( first ) onQuickAdd( first );
	}, [ fieldTypes, onQuickAdd ] );

	useEffect( () => {
		return () => {
			window.removeEventListener( 'pointermove', handleMove );
		};
	}, [ handleMove ] );

	/* ─── Panel resizing ─── */
	const resizeMeta = useRef( null );
	const onLeftResizeStart = useCallback(
		( e ) => {
			resizeMeta.current = { side: 'left', startX: e.clientX, startWidth: leftWidth };
			window.addEventListener( 'pointermove', onResizeMove );
			window.addEventListener( 'pointerup', onResizeEnd, { once: true } );
		},
		// eslint-disable-next-line react-hooks/exhaustive-deps
		[ leftWidth ]
	);
	const onRightResizeStart = useCallback(
		( e ) => {
			resizeMeta.current = { side: 'right', startX: e.clientX, startWidth: rightWidth };
			window.addEventListener( 'pointermove', onResizeMove );
			window.addEventListener( 'pointerup', onResizeEnd, { once: true } );
		},
		// eslint-disable-next-line react-hooks/exhaustive-deps
		[ rightWidth ]
	);
	function onResizeMove( e ) {
		const m = resizeMeta.current;
		if ( ! m ) return;
		if ( m.side === 'left' ) {
			setLeftWidth( clamp( m.startWidth + ( e.clientX - m.startX ), LEFT_MIN, LEFT_MAX ) );
		} else {
			setRightWidth( clamp( m.startWidth - ( e.clientX - m.startX ), RIGHT_MIN, RIGHT_MAX ) );
		}
	}
	function onResizeEnd() {
		resizeMeta.current = null;
		window.removeEventListener( 'pointermove', onResizeMove );
	}

	/* ─── Derived values ─── */
	const selectedField = state.fields.find( ( f ) => f.id === state.ui.selectedId ) || null;
	const saveDotClass =
		state.ui.saveState === 'saved' ? 'is-saved' : state.ui.saveState === 'saving' ? 'is-saving' : 'is-dirty';
	const saveLabel =
		state.ui.saveState === 'saving' ? 'Saving…' : state.ui.saveState === 'dirty' ? 'Unsaved changes' : formatSavedLabel( state.ui.lastSavedAt );

	return (
		<div className="mailpilot-fb" style={ { '--fb-left-width': `${ leftWidth }px`, '--fb-right-width': `${ rightWidth }px` } }>
			<Toolbar
				title={ state.title }
				onSetTitle={ ( v ) => dispatch( { type: 'SET_TITLE', value: v } ) }
				saveDotClass={ saveDotClass }
				saveLabel={ saveLabel }
				onUndo={ () => dispatch( { type: 'UNDO' } ) }
				onRedo={ () => dispatch( { type: 'REDO' } ) }
				canUndo={ state.ui.undoStack.length > 0 }
				canRedo={ state.ui.redoStack.length > 0 }
				device={ state.ui.device }
				onSetDevice={ ( v ) => dispatch( { type: 'SET_DEVICE', value: v } ) }
				status={ state.status }
				statusMenuOpen={ state.ui.statusMenuOpen }
				onToggleStatusMenu={ () => dispatch( { type: 'TOGGLE_STATUS_MENU' } ) }
				onSetStatus={ ( v ) => dispatch( { type: 'SET_STATUS', value: v } ) }
				onCloseMenus={ () => dispatch( { type: 'CLOSE_MENUS' } ) }
				embedMenuOpen={ state.ui.embedMenuOpen }
				onToggleEmbedMenu={ () => dispatch( { type: 'TOGGLE_EMBED_MENU' } ) }
				displayTypes={ displayTypes }
				displayType={ state.display_type }
				onSetDisplayType={ ( v ) => dispatch( { type: 'SET_DISPLAY_TYPE', value: v } ) }
				shortcode={ state.shortcode }
				onCopyShortcode={ () => {
					if ( state.shortcode && navigator.clipboard ) {
						navigator.clipboard.writeText( state.shortcode ).catch( () => {} );
					}
					dispatch( { type: 'SHOW_TOAST', message: 'Shortcode copied' } );
				} }
				onOpenPreview={ () => dispatch( { type: 'OPEN_PREVIEW' } ) }
				onSave={ doSave }
				saving={ state.ui.saveState === 'saving' }
				listUrl={ config.listUrl }
			/>

			<div className="fb-body">
				<FieldLibrary
					fieldTypes={ fieldTypes }
					search={ state.ui.search }
					favorites={ state.ui.favorites }
					recent={ state.ui.recent }
					collapsedCats={ state.ui.collapsedCats }
					onSetSearch={ ( v ) => dispatch( { type: 'SET_SEARCH', value: v } ) }
					onToggleCat={ ( cat ) => dispatch( { type: 'TOGGLE_CAT', cat } ) }
					onToggleFavorite={ ( t ) => dispatch( { type: 'TOGGLE_FAVORITE', fieldType: t } ) }
					onItemPointerDown={ onItemPointerDown }
					onQuickAdd={ onQuickAdd }
				/>

				<div
					role="separator"
					aria-orientation="vertical"
					aria-label="Resize field library"
					className="fb-resize-handle"
					onPointerDown={ onLeftResizeStart }
				>
					<div className="fb-resize-grip" />
				</div>

				<Canvas
					canvasRef={ canvasRef }
					cardsRef={ cardsRef }
					fields={ state.fields }
					fieldTypes={ fieldTypes }
					selectedId={ state.ui.selectedId }
					device={ state.ui.device }
					title={ state.title }
					onSetTitle={ ( v ) => dispatch( { type: 'SET_TITLE', value: v } ) }
					dragState={ dragState }
					onSelectField={ ( id ) => dispatch( { type: 'SELECT_FIELD', id } ) }
					onDuplicateField={ ( id ) => dispatch( { type: 'DUPLICATE_FIELD', id } ) }
					onDeleteField={ ( id ) => dispatch( { type: 'DELETE_FIELD', id } ) }
					onGripPointerDown={ onGripPointerDown }
					onAddFirstField={ onAddFirstField }
				/>

				<div
					role="separator"
					aria-orientation="vertical"
					aria-label="Resize properties panel"
					className="fb-resize-handle"
					onPointerDown={ onRightResizeStart }
				>
					<div className="fb-resize-grip" />
				</div>

				<PropertiesPanel
					tab={ state.ui.tab }
					onSetTab={ ( v ) => dispatch( { type: 'SET_TAB', value: v } ) }
					selectedField={ selectedField }
					allFields={ state.fields }
					fieldTypes={ fieldTypes }
					openFieldSections={ state.ui.openFieldSections }
					onToggleFieldSection={ ( section ) => dispatch( { type: 'TOGGLE_FIELD_SECTION', section } ) }
					onPatchField={ ( patch ) => selectedField && dispatch( { type: 'UPDATE_FIELD', id: selectedField.id, patch } ) }
					onToggleLogic={ ( v ) => selectedField && dispatch( { type: 'UPDATE_FIELD', id: selectedField.id, patch: { logicEnabled: v } } ) }
					onSetLogicMatch={ ( v ) => selectedField && dispatch( { type: 'UPDATE_FIELD', id: selectedField.id, patch: { logicMatch: v } } ) }
					onSetLogicAction={ ( v ) => selectedField && dispatch( { type: 'UPDATE_FIELD', id: selectedField.id, patch: { logicAction: v } } ) }
					onAddRule={ () => selectedField && dispatch( { type: 'ADD_LOGIC_RULE', id: selectedField.id } ) }
					onUpdateRule={ ( ruleId, patch ) => selectedField && dispatch( { type: 'UPDATE_LOGIC_RULE', id: selectedField.id, ruleId, patch } ) }
					onRemoveRule={ ( ruleId ) => selectedField && dispatch( { type: 'REMOVE_LOGIC_RULE', id: selectedField.id, ruleId } ) }
					title={ state.title }
					onSetTitle={ ( v ) => dispatch( { type: 'SET_TITLE', value: v } ) }
					settings={ state.settings }
					actions={ state.actions }
					providers={ providers }
					onPatchSettings={ ( patch ) => dispatch( { type: 'PATCH_SETTINGS', patch } ) }
					onPatchActions={ ( patch ) => dispatch( { type: 'PATCH_ACTIONS', patch } ) }
					onToggleProvider={ ( id ) => dispatch( { type: 'TOGGLE_PROVIDER', id } ) }
					openFormSections={ state.ui.openFormSections }
					onToggleFormSection={ ( section ) => dispatch( { type: 'TOGGLE_FORM_SECTION', section } ) }
				/>
			</div>

			{ dragState && dragState.started && dragState.ghost && (
				<div className="fb-drag-ghost" style={ { left: dragState.x + 14, top: dragState.y + 14 } } aria-hidden="true">
					{ dragState.ghost.label }
				</div>
			) }

			<PreviewModal
				open={ state.ui.previewOpen }
				onClose={ () => dispatch( { type: 'CLOSE_PREVIEW' } ) }
				title={ state.title }
				fields={ state.fields }
				device={ state.ui.device }
				buttonText={ state.settings.button_text }
			/>

			<Toast toast={ state.ui.toast } />
		</div>
	);
}
