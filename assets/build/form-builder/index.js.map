/**
 * A single field card on the canvas: header (grip, icon, label, required
 * badge, hover actions) + a per-type mock preview + optional logic summary.
 */
import { Copy, Settings2, Trash2, GitBranch } from 'lucide-react';
import { metaFor, previewKind, previewText, typeLabel } from '../utils';
import { CAT_TINTS } from '../constants';
import { IconChip } from './Primitives';

function GripIcon( props ) {
	return (
		<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="none" { ...props }>
			<circle cx="9" cy="5" r="1.6" />
			<circle cx="9" cy="12" r="1.6" />
			<circle cx="9" cy="19" r="1.6" />
			<circle cx="15" cy="5" r="1.6" />
			<circle cx="15" cy="12" r="1.6" />
			<circle cx="15" cy="19" r="1.6" />
		</svg>
	);
}

export function FieldPreview( { field } ) {
	const kind = previewKind( field );
	const text = previewText( field );
	const opts = ( field.options || [] ).map( ( o ) => o.label || o.value );

	if ( kind === 'nameSplit' ) {
		return (
			<div className="fb-mock-grid-2">
				<div className="fb-mock-input">First name</div>
				<div className="fb-mock-input">Last name</div>
			</div>
		);
	}
	if ( kind === 'textarea' ) {
		return <div className="fb-mock-input fb-mock-textarea">{ text }</div>;
	}
	if ( kind === 'select' ) {
		return (
			<div className="fb-mock-select">
				{ text }
				<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B7BEC9" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
					<path d="m6 9 6 6 6-6" />
				</svg>
			</div>
		);
	}
	if ( kind === 'radio' ) {
		return (
			<div className="fb-mock-option-list">
				{ ( opts.length ? opts : [ 'Option 1', 'Option 2' ] ).map( ( o, i ) => (
					<div className="fb-mock-option" key={ i }>
						<span className="fb-mock-radio-dot" />
						{ o }
					</div>
				) ) }
			</div>
		);
	}
	if ( kind === 'checkbox' ) {
		return (
			<div className="fb-mock-option-list">
				{ ( opts.length ? opts : [ 'Option 1', 'Option 2' ] ).map( ( o, i ) => (
					<div className="fb-mock-option" key={ i }>
						<span className="fb-mock-check-box" />
						{ o }
					</div>
				) ) }
			</div>
		);
	}
	if ( kind === 'hidden' ) {
		return (
			<div className="fb-mock-hidden">
				<svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round">
					<path d="M9.88 9.88a3 3 0 1 0 4.24 4.24" />
					<path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68" />
					<path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61" />
					<line x1="2" x2="22" y1="2" y2="22" />
				</svg>
				Hidden field — not visible to visitors
			</div>
		);
	}
	return <div className="fb-mock-input">{ text }</div>;
}

export default function FieldCard( {
	field,
	fieldTypes,
	selected,
	dragging,
	onSelect,
	onDuplicate,
	onDelete,
	onGripPointerDown,
} ) {
	const meta = metaFor( field.type );
	const tint = CAT_TINTS[ meta.cat ] || CAT_TINTS.basic;
	const label = typeLabel( field.type, fieldTypes );

	let logicSummary = '';
	if ( field.logicEnabled && field.rules && field.rules.length ) {
		const verb = field.logicAction === 'hide' ? 'Hidden' : 'Shown';
		logicSummary = `${ verb } based on ${ field.rules.length } condition${ field.rules.length > 1 ? 's' : '' }`;
	}

	return (
		<div
			className={ `fb-field-card${ selected ? ' is-selected' : '' }${ dragging ? ' is-dragging' : '' }` }
			data-card-id={ field.id }
			tabIndex={ 0 }
			role="button"
			aria-label={ `${ field.label || label } field` }
			onClick={ onSelect }
			onKeyDown={ ( e ) => {
				if ( e.key === 'Enter' || e.key === ' ' ) onSelect();
			} }
		>
			<div className="fb-card-header">
				<button
					type="button"
					className="fb-card-grip fb-reveal"
					aria-label="Drag to reorder"
					title="Drag to reorder"
					onPointerDown={ onGripPointerDown }
				>
					<GripIcon />
				</button>
				<IconChip icon={ meta.icon } bg={ tint.bg } fg={ tint.fg } />
				<span className="fb-card-title-wrap">
					<span className="fb-card-label">{ field.label || label }</span>
					<span className="fb-card-type">{ label }</span>
				</span>
				{ field.required && <span className="fb-required-badge">Required</span> }
				<span className="fb-card-actions fb-reveal">
					<button type="button" className="fb-card-action-btn" aria-label="Duplicate field" title="Duplicate" onClick={ ( e ) => { e.stopPropagation(); onDuplicate(); } }>
						<Copy size={ 14 } />
					</button>
					<button type="button" className="fb-card-action-btn" aria-label="Field settings" title="Settings" onClick={ ( e ) => { e.stopPropagation(); onSelect(); } }>
						<Settings2 size={ 14 } />
					</button>
					<button type="button" className="fb-card-action-btn is-danger" aria-label="Delete field" title="Delete" onClick={ ( e ) => { e.stopPropagation(); onDelete(); } }>
						<Trash2 size={ 14 } />
					</button>
				</span>
			</div>

			<FieldPreview field={ field } />

			{ logicSummary && (
				<div className="fb-logic-summary">
					<GitBranch size={ 12 } />
					{ logicSummary }
				</div>
			) }
		</div>
	);
}
