/**
 * Form Builder entry point. Mounts the React app into
 * `#mailpilot-builder-root` (printed by `FormsPage::render_builder()`).
 */
import { createRoot } from '@wordpress/element';
import App from './App';
import './index.css';

const mount = document.getElementById( 'mailpilot-builder-root' );

if ( mount ) {
	mount.classList.remove( 'mailpilot-builder-loading' );
	mount.textContent = '';
	const root = createRoot( mount );
	root.render( <App /> );
}
