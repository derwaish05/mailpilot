/**
 * Small stateless helpers shared across the Form Builder: id generation,
 * field factories, and the UI-field <-> REST-field mapping.
 *
 * Backend note: `src/Rest/FormsController.php::parse_fields()` and
 * `src/Forms/Field.php` only understand
 * `key/type/label/required/placeholder/default/options/validation/conditional/name_mode`.
 * Everything else on a UI field (helpText, charLimit, errorMsg, width, size,
 * radius, hideLabel, prefix, suffix, autocomplete, cssClass, and the
 * multi-rule conditional-logic builder) is a builder-only affordance that
 * does not round-trip through a save/reload cycle — see the deliberate
 * simplifications called out in the delivery report.
 */
import { FIELD_META, DEFAULT_FIELD_META } from './constants';

let seq = 1;

export function uid( prefix = 'id' ) {
	seq += 1;
	return `${ prefix }-${ Date.now().toString( 36 ) }-${ seq.toString( 36 ) }-${ Math.floor( Math.random() * 1e6 ).toString( 36 ) }`;
}

export function metaFor( type ) {
	return FIELD_META[ type ] || DEFAULT_FIELD_META;
}

export function sanitizeKey( str ) {
	return ( str || '' )
		.toString()
		.toLowerCase()
		.replace( /[^a-z0-9]+/g, '_' )
		.replace( /^_+|_+$/g, '' );
}

export function makeUniqueKey( base, existingKeys ) {
	let key = sanitizeKey( base ) || 'field';
	let i = 1;
	let candidate = key;
	while ( existingKeys.includes( candidate ) ) {
		i += 1;
		candidate = `${ key }_${ i }`;
	}
	return candidate;
}

/**
 * Build a fresh UI-side field for a given type descriptor
 * (`{type,label,hasOptions}` from `MailPilotBuilder.fieldTypes`).
 */
export function createField( typeDescriptor, existingFields ) {
	const existingKeys = existingFields.map( ( f ) => f.key );
	const key = makeUniqueKey( typeDescriptor.type, existingKeys );

	return {
		id: uid( 'f' ),
		key,
		type: typeDescriptor.type,
		label: typeDescriptor.label,
		required: false,
		placeholder: '',
		default: '',
		options: typeDescriptor.hasOptions
			? [
					{ value: 'option_1', label: 'Option 1' },
					{ value: 'option_2', label: 'Option 2' },
			  ]
			: [],
		validation: 'none',
		conditional: null,
		name_mode: 'single',
		// Builder-only appearance/advanced state (see file header note).
		helpText: '',
		charLimit: '',
		errorMsg: '',
		width: 'full',
		size: 'md',
		radius: 8,
		hideLabel: false,
		prefix: '',
		suffix: '',
		autocomplete: 'off',
		cssClass: '',
		logicEnabled: false,
		logicMatch: 'all',
		logicAction: 'show',
		rules: [],
	};
}

export function duplicateField( field, existingFields ) {
	const clone = deepClone( field );
	clone.id = uid( 'f' );
	clone.key = makeUniqueKey( `${ field.key }_copy`, existingFields.map( ( f ) => f.key ) );
	clone.label = field.label ? `${ field.label } (copy)` : field.label;
	return clone;
}

export function deepClone( value ) {
	return JSON.parse( JSON.stringify( value ) );
}

/**
 * Map a backend field (as returned by GET /forms/{id}) to full UI shape,
 * filling in defaults for the builder-only properties the backend doesn't
 * store.
 */
export function fromApiField( f ) {
	const rules = [];
	let logicEnabled = false;
	if ( f.conditional && f.conditional.field ) {
		logicEnabled = true;
		rules.push( {
			id: uid( 'r' ),
			field: f.conditional.field,
			operator: f.conditional.operator || 'is',
			value: f.conditional.value || '',
		} );
	}

	return {
		id: uid( 'f' ),
		key: f.key || '',
		type: f.type || 'name',
		label: f.label || '',
		required: !! f.required,
		placeholder: f.placeholder || '',
		default: f.default || '',
		options: Array.isArray( f.options ) ? f.options : [],
		validation: f.validation || 'none',
		conditional: f.conditional || null,
		name_mode: f.name_mode === 'split' ? 'split' : 'single',
		helpText: '',
		charLimit: '',
		errorMsg: '',
		width: 'full',
		size: 'md',
		radius: 8,
		hideLabel: false,
		prefix: '',
		suffix: '',
		autocomplete: 'off',
		cssClass: '',
		logicEnabled,
		logicMatch: 'all',
		logicAction: 'show',
		rules,
	};
}

/**
 * Map a UI field down to the shape the REST API accepts. Only the first
 * conditional-logic rule survives (the backend models a single
 * field/operator/value rule); when the action is "Hide" we best-effort
 * invert the operator so the single stored rule still matches backend
 * show-when-true semantics.
 */
export function toApiField( field ) {
	let conditional = null;
	if ( field.logicEnabled && field.rules && field.rules.length ) {
		const rule = field.rules[ 0 ];
		if ( rule.field ) {
			let operator = rule.operator;
			if ( field.logicAction === 'hide' ) {
				const invert = { is: 'is_not', is_not: 'is', empty: 'not_empty', not_empty: 'empty' };
				operator = invert[ operator ] || operator;
			}
			conditional = { field: rule.field, operator, value: rule.value || '' };
		}
	}

	return {
		key: field.key,
		type: field.type,
		label: field.label,
		required: !! field.required,
		placeholder: field.placeholder,
		default: field.default,
		options: field.options,
		validation: field.validation,
		conditional,
		name_mode: field.name_mode,
	};
}

/** Which mock preview a field card / preview-modal row should render. */
export function previewKind( field ) {
	if ( field.type === 'name' && field.name_mode === 'split' ) return 'nameSplit';
	if ( field.type === 'textarea' ) return 'textarea';
	if ( field.type === 'dropdown' ) return 'select';
	if ( field.type === 'radio' ) return 'radio';
	if ( field.type === 'checkbox' ) return 'checkbox';
	if ( field.type === 'hidden' ) return 'hidden';
	return 'input';
}

export function previewText( field ) {
	return field.placeholder || metaFor( field.type ).ph || field.label || '';
}

export function typeLabel( type, fieldTypes ) {
	const found = ( fieldTypes || [] ).find( ( t ) => t.type === type );
	return found ? found.label : type;
}

export function clamp( n, min, max ) {
	return Math.min( max, Math.max( min, n ) );
}

export function debounce( fn, wait ) {
	let t;
	function debounced( ...args ) {
		clearTimeout( t );
		t = setTimeout( () => fn( ...args ), wait );
	}
	debounced.cancel = () => clearTimeout( t );
	return debounced;
}
