/**
 * REST wiring for the Form Builder. Talks to `mailpilot/v1/forms` using
 * @wordpress/api-fetch, authenticated with the `wp_rest` nonce localized
 * onto `window.MailPilotBuilder`.
 */
import apiFetch from '@wordpress/api-fetch';

const cfg = window.MailPilotBuilder || {};

if ( cfg.nonce ) {
	apiFetch.use( apiFetch.createNonceMiddleware( cfg.nonce ) );
}

/**
 * Fetch a form by id.
 */
export function fetchForm( id ) {
	return apiFetch( { url: `${ cfg.restBase }/${ id }`, method: 'GET' } );
}

/**
 * Create (id === 0) or update a form.
 */
export function saveForm( id, payload ) {
	const url = id && id > 0 ? `${ cfg.restBase }/${ id }` : cfg.restBase;
	return apiFetch( { url, method: 'POST', data: payload } );
}

export const config = cfg;
