/**
 * Right panel: Field tab (General / Validation / Appearance / Advanced /
 * Conditional Logic) and Form tab (General / Confirmation / Notifications &
 * Integrations / Privacy & Spam / Custom Code), per README §Screens item 4
 * and DESIGN_SYSTEM §3.10–3.11.
 */
import {
	MousePointer2,
	CheckCircle2,
	Palette,
	Wrench,
	GitBranch,
	FileText,
	Bell,
	Lock,
	Code2,
	ChevronRight,
	Plus,
	X,
	HelpCircle,
	ExternalLink,
} from 'lucide-react';
import { Switch, Segmented, IconChip } from './Primitives';
import {
	OPERATORS,
	VALIDATION_TYPES,
	AUTOCOMPLETE_OPTIONS,
	AUDIENCE_OPTIONS,
	WIDTH_OPTIONS,
	SIZE_OPTIONS,
} from '../constants';
import { metaFor, typeLabel, sanitizeKey } from '../utils';

const NAME_FORMAT_OPTS = [
	{ value: 'single', label: 'Single' },
	{ value: 'split', label: 'First / Last' },
];
const SPAM_OPTS = [
	{ value: 'off', label: 'Off' },
	{ value: 'honeypot', label: 'Honeypot' },
	{ value: 'recaptcha', label: 'reCAPTCHA' },
];

function Section( { icon: Icon, tint, title, badge, open, onToggle, children } ) {
	return (
		<div className="fb-section">
			<button type="button" className="fb-section-header" aria-expanded={ open } onClick={ onToggle }>
				<span className="fb-section-icon" style={ { background: tint.bg, color: tint.fg } }>
					<Icon size={ 14 } strokeWidth={ 2 } />
				</span>
				<span className="fb-section-title">{ title }</span>
				{ badge && <span className="fb-section-badge">{ badge }</span> }
				<ChevronRight size={ 14 } className={ `fb-section-chevron${ open ? ' is-open' : '' }` } />
			</button>
			{ open && <div className="fb-section-body">{ children }</div> }
		</div>
	);
}

function Field( { label, help, children } ) {
	return (
		<label style={ { display: 'block' } }>
			<span className={ `fb-field-label${ help ? ' with-help' : '' }` }>
				{ label }
				{ help && (
					<span className="fb-help-icon" title={ help }>
						<HelpCircle size={ 12 } />
					</span>
				) }
			</span>
			{ children }
		</label>
	);
}

function Row( { label, sub, children } ) {
	return (
		<div className="fb-row-between">
			<span style={ { minWidth: 0 } }>
				<span className="fb-row-label">{ label }</span>
				{ sub && <span className="fb-row-label-sub">{ sub }</span> }
			</span>
			{ children }
		</div>
	);
}

const TINTS = {
	blue: { bg: 'var(--fb-tint-blue)', fg: 'var(--fb-accent)' },
	purple: { bg: 'var(--fb-tint-purple)', fg: 'var(--fb-accent-purple)' },
	teal: { bg: 'var(--fb-tint-teal)', fg: '#0D9488' },
	pink: { bg: 'var(--fb-tint-pink)', fg: '#DB2777' },
	green: { bg: 'var(--fb-tint-green)', fg: 'var(--fb-success)' },
	orange: { bg: 'var(--fb-tint-orange)', fg: 'var(--fb-warning)' },
	gray: { bg: 'var(--fb-bg-hover)', fg: 'var(--fb-text-muted)' },
};

function OptionsEditor( { field, onPatch } ) {
	const options = field.options || [];

	function update( index, patch ) {
		const next = options.map( ( o, i ) => ( i === index ? { ...o, ...patch } : o ) );
		onPatch( { options: next } );
	}
	function add() {
		const n = options.length + 1;
		onPatch( { options: [ ...options, { value: `option_${ n }`, label: `Option ${ n }` } ] } );
	}
	function remove( index ) {
		onPatch( { options: options.filter( ( _, i ) => i !== index ) } );
	}

	return (
		<div>
			<span className="fb-field-label">Options</span>
			<div style={ { display: 'flex', flexDirection: 'column', gap: 6 } }>
				{ options.map( ( o, i ) => (
					<div key={ i } style={ { display: 'flex', gap: 6 } }>
						<input
							className="fb-input"
							value={ o.label }
							onChange={ ( e ) => update( i, { label: e.target.value, value: sanitizeKey( e.target.value ) || o.value } ) }
							placeholder={ `Option ${ i + 1 }` }
						/>
						<button type="button" className="fb-logic-remove-btn" aria-label="Remove option" onClick={ () => remove( i ) }>
							<X size={ 13 } />
						</button>
					</div>
				) ) }
				<button type="button" className="fb-logic-add-btn" onClick={ add } style={ { color: 'var(--fb-accent)' } }>
					<Plus size={ 13 } strokeWidth={ 2.5 } />
					Add option
				</button>
			</div>
		</div>
	);
}

function ConditionalLogic( { field, allFields, fieldTypes, onToggleLogic, onSetMatch, onSetAction, onAddRule, onUpdateRule, onRemoveRule } ) {
	const otherFields = allFields.filter( ( f ) => f.id !== field.id );

	return (
		<>
			<Row label="Enable conditional logic">
				<Switch checked={ field.logicEnabled } onChange={ onToggleLogic } label="Enable conditional logic" />
			</Row>
			{ field.logicEnabled && (
				<div className="fb-logic-card">
					<div className="fb-logic-if-row">
						<span className="fb-logic-overline">IF</span>
						<Segmented
							purple
							ariaLabel="Match"
							options={ [ { value: 'all', label: 'All' }, { value: 'any', label: 'Any' } ] }
							value={ field.logicMatch }
							onChange={ onSetMatch }
						/>
						<span className="fb-logic-match-hint">match</span>
					</div>

					{ field.rules.map( ( rule ) => (
						<div className="fb-logic-rule" key={ rule.id }>
							<div className="fb-logic-rule-row">
								<select
									className="fb-logic-select flex1"
									aria-label="Rule field"
									value={ rule.field }
									onChange={ ( e ) => onUpdateRule( rule.id, { field: e.target.value } ) }
								>
									<option value="">Select field…</option>
									{ otherFields.map( ( f ) => (
										<option value={ f.key } key={ f.id }>
											{ f.label || typeLabel( f.type, fieldTypes ) }
										</option>
									) ) }
								</select>
								<button type="button" className="fb-logic-remove-btn" aria-label="Remove rule" onClick={ () => onRemoveRule( rule.id ) }>
									<X size={ 13 } />
								</button>
							</div>
							<div className="fb-logic-rule-row">
								<select
									className="fb-logic-select w-110"
									aria-label="Rule operator"
									value={ rule.operator }
									onChange={ ( e ) => onUpdateRule( rule.id, { operator: e.target.value } ) }
								>
									{ OPERATORS.map( ( o ) => (
										<option value={ o.value } key={ o.value }>{ o.label }</option>
									) ) }
								</select>
								<input
									className="fb-logic-value-input"
									aria-label="Rule value"
									placeholder="Value"
									value={ rule.value }
									onChange={ ( e ) => onUpdateRule( rule.id, { value: e.target.value } ) }
								/>
							</div>
						</div>
					) ) }

					<button type="button" className="fb-logic-add-btn" onClick={ onAddRule }>
						<Plus size={ 13 } strokeWidth={ 2.5 } />
						Add condition
					</button>

					<div className="fb-logic-divider" />

					<div className="fb-logic-then-row">
						<span className="fb-logic-overline">THEN</span>
						<div style={ { flex: 1 } }>
							<Segmented
								purple
								ariaLabel="Action"
								options={ [ { value: 'show', label: 'Show' }, { value: 'hide', label: 'Hide' } ] }
								value={ field.logicAction }
								onChange={ onSetAction }
							/>
						</div>
						<span className="fb-logic-match-hint">this field</span>
					</div>
				</div>
			) }
		</>
	);
}

function FieldTab( { field, allFields, fieldTypes, open, onToggleSection, onPatch, onToggleLogic, onSetLogicMatch, onSetLogicAction, onAddRule, onUpdateRule, onRemoveRule } ) {
	if ( ! field ) {
		return (
			<div className="fb-no-selection">
				<div className="fb-no-selection-icon">
					<MousePointer2 size={ 20 } strokeWidth={ 2 } />
				</div>
				<div className="fb-no-selection-title">No field selected</div>
				<div className="fb-no-selection-desc">Click a field on the canvas to edit its properties.</div>
			</div>
		);
	}

	const meta = metaFor( field.type );
	const label = typeLabel( field.type, fieldTypes );
	const hasOptions = ( fieldTypes.find( ( t ) => t.type === field.type ) || {} ).hasOptions;

	return (
		<>
			<div className="fb-selected-header">
				<IconChip icon={ meta.icon } bg={ TINTS.blue.bg } fg={ TINTS.blue.fg } />
				<span style={ { minWidth: 0 } }>
					<span className="fb-selected-label">{ field.label || label }</span>
					<span className="fb-selected-type">{ label } field</span>
				</span>
			</div>

			<Section icon={ FileText } tint={ TINTS.blue } title="General" open={ open.general } onToggle={ () => onToggleSection( 'general' ) }>
				<Field label="Label">
					<input className="fb-input" value={ field.label } onChange={ ( e ) => onPatch( { label: e.target.value } ) } />
				</Field>
				{ hasOptions && <OptionsEditor field={ field } onPatch={ onPatch } /> }
				{ field.type === 'name' && (
					<div>
						<span className="fb-field-label">Name format</span>
						<Segmented options={ NAME_FORMAT_OPTS } value={ field.name_mode } onChange={ ( v ) => onPatch( { name_mode: v } ) } ariaLabel="Name format" />
					</div>
				) }
				<Field label="Placeholder">
					<input className="fb-input" value={ field.placeholder } onChange={ ( e ) => onPatch( { placeholder: e.target.value } ) } placeholder={ meta.ph || 'e.g. you@company.com' } />
				</Field>
				<Field label="Default value">
					<input className="fb-input" value={ field.default } onChange={ ( e ) => onPatch( { default: e.target.value } ) } />
				</Field>
				<Field label="Help text" help="Shown below the field to guide visitors">
					<input className="fb-input" value={ field.helpText } onChange={ ( e ) => onPatch( { helpText: e.target.value } ) } />
				</Field>
				<Row label="Required">
					<Switch checked={ field.required } onChange={ ( v ) => onPatch( { required: v } ) } label="Required" />
				</Row>
			</Section>

			<Section icon={ CheckCircle2 } tint={ TINTS.teal } title="Validation" open={ open.validation } onToggle={ () => onToggleSection( 'validation' ) }>
				<Field label="Validation type">
					<select className="fb-select" value={ field.validation } onChange={ ( e ) => onPatch( { validation: e.target.value } ) }>
						{ VALIDATION_TYPES.map( ( o ) => <option value={ o.value } key={ o.value }>{ o.label }</option> ) }
					</select>
				</Field>
				<Field label="Character limit">
					<input type="number" className="fb-input" value={ field.charLimit } onChange={ ( e ) => onPatch( { charLimit: e.target.value } ) } placeholder="No limit" />
				</Field>
				<Field label="Custom error message">
					<input className="fb-input" value={ field.errorMsg } onChange={ ( e ) => onPatch( { errorMsg: e.target.value } ) } placeholder="Please enter a valid value" />
				</Field>
			</Section>

			<Section icon={ Palette } tint={ TINTS.pink } title="Appearance" open={ open.appearance } onToggle={ () => onToggleSection( 'appearance' ) }>
				<div>
					<span className="fb-field-label">Field width</span>
					<Segmented options={ WIDTH_OPTIONS } value={ field.width } onChange={ ( v ) => onPatch( { width: v } ) } ariaLabel="Field width" />
				</div>
				<div>
					<span className="fb-field-label">Size</span>
					<Segmented options={ SIZE_OPTIONS } value={ field.size } onChange={ ( v ) => onPatch( { size: v } ) } ariaLabel="Size" />
				</div>
				<div>
					<div className="fb-range-label-row">
						Corner radius <span className="fb-range-value">{ field.radius }px</span>
					</div>
					<input type="range" min="0" max="16" className="fb-range" value={ field.radius } onChange={ ( e ) => onPatch( { radius: Number( e.target.value ) } ) } />
				</div>
				<Row label="Hide label">
					<Switch checked={ field.hideLabel } onChange={ ( v ) => onPatch( { hideLabel: v } ) } label="Hide label" />
				</Row>
			</Section>

			<Section icon={ Wrench } tint={ TINTS.gray } title="Advanced" open={ open.advanced } onToggle={ () => onToggleSection( 'advanced' ) }>
				<Field label="Field key">
					<input className="fb-input is-mono" value={ field.key } onChange={ ( e ) => onPatch( { key: sanitizeKey( e.target.value ) } ) } />
				</Field>
				<div className="fb-input-grid-2">
					<Field label="Prefix">
						<input className="fb-input" value={ field.prefix } onChange={ ( e ) => onPatch( { prefix: e.target.value } ) } placeholder="$" />
					</Field>
					<Field label="Suffix">
						<input className="fb-input" value={ field.suffix } onChange={ ( e ) => onPatch( { suffix: e.target.value } ) } placeholder=".00" />
					</Field>
				</div>
				<Field label="Autocomplete">
					<select className="fb-select" value={ field.autocomplete } onChange={ ( e ) => onPatch( { autocomplete: e.target.value } ) }>
						{ AUTOCOMPLETE_OPTIONS.map( ( o ) => <option value={ o.value } key={ o.value }>{ o.label }</option> ) }
					</select>
				</Field>
				<Field label="CSS class">
					<input className="fb-input is-mono" value={ field.cssClass } onChange={ ( e ) => onPatch( { cssClass: e.target.value } ) } placeholder="my-custom-class" />
				</Field>
			</Section>

			<Section icon={ GitBranch } tint={ TINTS.purple } title="Conditional Logic" open={ open.logic } onToggle={ () => onToggleSection( 'logic' ) }>
				<ConditionalLogic
					field={ field }
					allFields={ allFields }
					fieldTypes={ fieldTypes }
					onToggleLogic={ ( v ) => onToggleLogic( v ) }
					onSetMatch={ ( v ) => onSetLogicMatch( v ) }
					onSetAction={ ( v ) => onSetLogicAction( v ) }
					onAddRule={ onAddRule }
					onUpdateRule={ onUpdateRule }
					onRemoveRule={ onRemoveRule }
				/>
			</Section>
		</>
	);
}

function FormTab( {
	title,
	onSetTitle,
	settings,
	actions,
	providers,
	onPatchSettings,
	onPatchActions,
	onToggleProvider,
	open,
	onToggleSection,
} ) {
	const tagsValue = ( settings.tags || [] ).join( ', ' );

	return (
		<>
			<Section icon={ FileText } tint={ TINTS.blue } title="General" open={ open.general } onToggle={ () => onToggleSection( 'general' ) }>
				<Field label="Form name">
					<input className="fb-input" value={ title } onChange={ ( e ) => onSetTitle( e.target.value ) } />
				</Field>
				<Field label="Description">
					<textarea className="fb-textarea" rows={ 3 } value={ settings.description } onChange={ ( e ) => onPatchSettings( { description: e.target.value } ) } placeholder="Internal note about this form…" />
				</Field>
				<Field label="Tags">
					<input
						className="fb-input"
						value={ tagsValue }
						onChange={ ( e ) => onPatchSettings( { tags: e.target.value.split( ',' ).map( ( t ) => t.trim() ).filter( Boolean ) } ) }
						placeholder="newsletter, signup"
					/>
				</Field>
				<Field label="Audience">
					<select className="fb-select" value={ settings.audience } onChange={ ( e ) => onPatchSettings( { audience: e.target.value } ) }>
						<option value="">—</option>
						{ AUDIENCE_OPTIONS.map( ( a ) => <option value={ a } key={ a }>{ a }</option> ) }
					</select>
				</Field>
			</Section>

			<Section icon={ CheckCircle2 } tint={ TINTS.green } title="Confirmation" open={ open.confirm } onToggle={ () => onToggleSection( 'confirm' ) }>
				<Field label="Success message">
					<textarea className="fb-textarea" rows={ 2 } value={ settings.success_message } onChange={ ( e ) => onPatchSettings( { success_message: e.target.value } ) } />
				</Field>
				<Row label="Redirect after submit">
					<Switch
						checked={ !! settings.redirect_enabled }
						onChange={ ( v ) => {
							onPatchSettings( { redirect_enabled: v } );
							if ( ! v ) onPatchActions( { redirect: '' } );
						} }
						label="Redirect after submit"
					/>
				</Row>
				{ settings.redirect_enabled && (
					<input
						className="fb-input"
						value={ actions.redirect || '' }
						onChange={ ( e ) => onPatchActions( { redirect: e.target.value } ) }
						placeholder="https://example.com/thank-you"
					/>
				) }
				<Row label="Double opt-in" sub="Send a confirmation email first">
					<Switch checked={ !! settings.double_opt_in } onChange={ ( v ) => onPatchSettings( { double_opt_in: v } ) } label="Double opt-in" />
				</Row>
			</Section>

			<Section icon={ Bell } tint={ TINTS.orange } title="Notifications & Integrations" open={ open.notify } onToggle={ () => onToggleSection( 'notify' ) }>
				<Row label="Email notifications">
					<Switch checked={ !! settings.notify } onChange={ ( v ) => onPatchSettings( { notify: v } ) } label="Email notifications" />
				</Row>
				{ settings.notify && (
					<Field label="Send to">
						<input className="fb-input" value={ settings.notify_email } onChange={ ( e ) => onPatchSettings( { notify_email: e.target.value } ) } />
					</Field>
				) }
				<div className="fb-info-tile">
					<span className="fb-info-tile-icon">
						<ExternalLink size={ 14 } />
					</span>
					<span className="fb-info-tile-text">
						<span className="fb-info-tile-title">Integrations</span>
						<span className="fb-info-tile-desc">Connected providers post signups on submit</span>
					</span>
				</div>
				{ providers.length === 0 && <span className="fb-empty-note">No providers connected yet. Connect one under MailPilot → Integrations.</span> }
				{ providers.length > 0 && (
					<div className="fb-provider-list">
						{ providers.map( ( p ) => (
							<label className="fb-provider-row" key={ p.id }>
								<input
									type="checkbox"
									checked={ ( actions.providers || [] ).includes( p.id ) }
									onChange={ () => onToggleProvider( p.id ) }
								/>
								{ p.label }
							</label>
						) ) }
					</div>
				) }
			</Section>

			<Section icon={ Lock } tint={ TINTS.gray } title="Privacy & Spam" open={ open.compliance } onToggle={ () => onToggleSection( 'compliance' ) }>
				<Row label="GDPR consent" sub="Require explicit consent checkbox">
					<Switch checked={ !! settings.gdpr } onChange={ ( v ) => onPatchSettings( { gdpr: v } ) } label="GDPR consent" />
				</Row>
				<div>
					<span className="fb-field-label">Spam protection</span>
					<Segmented options={ SPAM_OPTS } value={ settings.spam_protection } onChange={ ( v ) => onPatchSettings( { spam_protection: v } ) } ariaLabel="Spam protection" />
				</div>
			</Section>

			<Section icon={ Code2 } tint={ TINTS.teal } title="Custom Code" open={ open.code } onToggle={ () => onToggleSection( 'code' ) }>
				<Field label="Custom CSS">
					<textarea className="fb-textarea is-code" rows={ 4 } spellCheck="false" value={ settings.custom_css } onChange={ ( e ) => onPatchSettings( { custom_css: e.target.value } ) } placeholder=".my-form { }" />
				</Field>
				<Field label="Custom JS">
					<textarea className="fb-textarea is-code" rows={ 4 } spellCheck="false" value={ settings.custom_js } onChange={ ( e ) => onPatchSettings( { custom_js: e.target.value } ) } placeholder="// runs after form render" />
				</Field>
			</Section>
		</>
	);
}

export default function PropertiesPanel( props ) {
	const {
		tab,
		onSetTab,
		selectedField,
		allFields,
		fieldTypes,
		openFieldSections,
		onToggleFieldSection,
		onPatchField,
		onToggleLogic,
		onSetLogicMatch,
		onSetLogicAction,
		onAddRule,
		onUpdateRule,
		onRemoveRule,
		title,
		onSetTitle,
		settings,
		actions,
		providers,
		onPatchSettings,
		onPatchActions,
		onToggleProvider,
		openFormSections,
		onToggleFormSection,
	} = props;

	return (
		<aside className="fb-panel" style={ { width: 'var(--fb-right-width, 336px)' } }>
			<div role="tablist" className="fb-tabs">
				<button role="tab" aria-selected={ tab === 'field' } className={ `fb-tab${ tab === 'field' ? ' is-active' : '' }` } onClick={ () => onSetTab( 'field' ) }>
					Field
				</button>
				<button role="tab" aria-selected={ tab === 'form' } className={ `fb-tab${ tab === 'form' ? ' is-active' : '' }` } onClick={ () => onSetTab( 'form' ) }>
					Form
				</button>
			</div>
			<div className="fb-properties-body">
				{ tab === 'field' && (
					<FieldTab
						field={ selectedField }
						allFields={ allFields }
						fieldTypes={ fieldTypes }
						open={ openFieldSections }
						onToggleSection={ onToggleFieldSection }
						onPatch={ onPatchField }
						onToggleLogic={ onToggleLogic }
						onSetLogicMatch={ onSetLogicMatch }
						onSetLogicAction={ onSetLogicAction }
						onAddRule={ onAddRule }
						onUpdateRule={ onUpdateRule }
						onRemoveRule={ onRemoveRule }
					/>
				) }
				{ tab === 'form' && (
					<FormTab
						title={ title }
						onSetTitle={ onSetTitle }
						settings={ settings }
						actions={ actions }
						providers={ providers }
						onPatchSettings={ onPatchSettings }
						onPatchActions={ onPatchActions }
						onToggleProvider={ onToggleProvider }
						open={ openFormSections }
						onToggleSection={ onToggleFormSection }
					/>
				) }
			</div>
		</aside>
	);
}
