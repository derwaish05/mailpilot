/**
 * Form Builder state: a single useReducer store for form/fields/ui, with
 * undo/redo snapshotting of the `fields` array (cap 50) per
 * DESIGN_SYSTEM.md §4.
 */
import { UNDO_CAP } from './constants';
import { createField, duplicateField, deepClone, fromApiField, uid } from './utils';

export function initialState() {
	return {
		loaded: false,
		id: 0,
		title: 'Untitled form',
		status: 'draft',
		display_type: 'inline',
		shortcode: '',
		settings: {
			button_text: 'Subscribe',
			success_message: 'Thanks for subscribing!',
			double_opt_in: false,
			description: '',
			tags: [],
			audience: '',
			notify: false,
			notify_email: '',
			gdpr: false,
			spam_protection: 'off',
			custom_css: '',
			custom_js: '',
			// Client-only convenience flag (backend infers "redirect enabled"
			// from `actions.redirect` being non-empty; this key is never sent
			// to — or read from — the REST API).
			redirect_enabled: false,
		},
		actions: {
			apply_tags: [],
			providers: [],
			webhook: '',
			redirect: '',
			lead_magnet: 0,
		},
		fields: [],
		ui: {
			selectedId: null,
			tab: 'field',
			device: 'desktop',
			search: '',
			favorites: loadLocal( 'mailpilot_fb_favorites', [] ),
			recent: loadLocal( 'mailpilot_fb_recent', [] ),
			collapsedCats: {},
			openFieldSections: { general: true, validation: false, appearance: false, advanced: false, logic: false },
			openFormSections: { general: true, confirm: false, notify: false, compliance: false, code: false },
			undoStack: [],
			redoStack: [],
			saveState: 'saved',
			lastSavedAt: null,
			statusMenuOpen: false,
			embedMenuOpen: false,
			previewOpen: false,
			toast: null,
		},
	};
}

function loadLocal( key, fallback ) {
	try {
		const raw = window.localStorage.getItem( key );
		return raw ? JSON.parse( raw ) : fallback;
	} catch ( e ) {
		return fallback;
	}
}

export function saveLocal( key, value ) {
	try {
		window.localStorage.setItem( key, JSON.stringify( value ) );
	} catch ( e ) {
		// ignore (private browsing / quota)
	}
}

function withHistory( state, nextFields ) {
	const undoStack = [ ...state.ui.undoStack, deepClone( state.fields ) ].slice( -UNDO_CAP );
	return {
		...state,
		fields: nextFields,
		ui: { ...state.ui, undoStack, redoStack: [], saveState: 'dirty' },
	};
}

function dirty( state, patch ) {
	return { ...state, ...patch, ui: { ...state.ui, ...( patch.ui || {} ), saveState: 'dirty' } };
}

export function reducer( state, action ) {
	switch ( action.type ) {
		case 'LOAD': {
			const data = action.payload;
			return {
				...state,
				loaded: true,
				id: data.id || 0,
				title: data.title || 'Untitled form',
				status: data.status || 'draft',
				display_type: data.display_type || 'inline',
				shortcode: data.shortcode || '',
				settings: {
					...state.settings,
					...( data.settings || {} ),
					redirect_enabled: !! ( data.actions && data.actions.redirect ),
				},
				actions: { ...state.actions, ...( data.actions || {} ) },
				fields: ( data.fields || [] ).map( fromApiField ),
				ui: { ...state.ui, saveState: 'saved', lastSavedAt: Date.now() },
			};
		}

		case 'NEW_FORM_READY':
			return { ...state, loaded: true };

		case 'SET_TITLE':
			return dirty( state, { title: action.value } );

		case 'SET_STATUS':
			return dirty( state, { status: action.value, ui: { statusMenuOpen: false } } );

		case 'SET_DISPLAY_TYPE':
			return dirty( state, { display_type: action.value, ui: { embedMenuOpen: false } } );

		case 'PATCH_SETTINGS':
			return dirty( state, { settings: { ...state.settings, ...action.patch } } );

		case 'PATCH_ACTIONS':
			return dirty( state, { actions: { ...state.actions, ...action.patch } } );

		case 'TOGGLE_PROVIDER': {
			const current = state.actions.providers || [];
			const has = current.includes( action.id );
			const providers = has ? current.filter( ( p ) => p !== action.id ) : [ ...current, action.id ];
			return dirty( state, { actions: { ...state.actions, providers } } );
		}

		case 'ADD_FIELD': {
			const field = createField( action.typeDescriptor, state.fields );
			const index = typeof action.index === 'number' ? action.index : state.fields.length;
			const nextFields = [ ...state.fields ];
			nextFields.splice( index, 0, field );
			const next = withHistory( state, nextFields );
			return {
				...next,
				ui: { ...next.ui, selectedId: field.id, tab: 'field' },
			};
		}

		case 'MOVE_FIELD': {
			const { from, to } = action;
			if ( from === to || from == null || to == null ) return state;
			const nextFields = [ ...state.fields ];
			const [ moved ] = nextFields.splice( from, 1 );
			let insertAt = to;
			if ( from < to ) insertAt -= 1;
			nextFields.splice( insertAt, 0, moved );
			return withHistory( state, nextFields );
		}

		case 'UPDATE_FIELD': {
			const nextFields = state.fields.map( ( f ) => ( f.id === action.id ? { ...f, ...action.patch } : f ) );
			return withHistory( state, nextFields );
		}

		case 'DELETE_FIELD': {
			const nextFields = state.fields.filter( ( f ) => f.id !== action.id );
			const next = withHistory( state, nextFields );
			const selectedId = state.ui.selectedId === action.id ? null : state.ui.selectedId;
			return { ...next, ui: { ...next.ui, selectedId } };
		}

		case 'DUPLICATE_FIELD': {
			const original = state.fields.find( ( f ) => f.id === action.id );
			if ( ! original ) return state;
			const copy = duplicateField( original, state.fields );
			const idx = state.fields.findIndex( ( f ) => f.id === action.id );
			const nextFields = [ ...state.fields ];
			nextFields.splice( idx + 1, 0, copy );
			const next = withHistory( state, nextFields );
			return { ...next, ui: { ...next.ui, selectedId: copy.id, tab: 'field' } };
		}

		case 'SELECT_FIELD':
			return { ...state, ui: { ...state.ui, selectedId: action.id, tab: action.id ? 'field' : state.ui.tab } };

		case 'SET_TAB':
			return { ...state, ui: { ...state.ui, tab: action.value } };

		case 'SET_DEVICE':
			return { ...state, ui: { ...state.ui, device: action.value } };

		case 'SET_SEARCH':
			return { ...state, ui: { ...state.ui, search: action.value } };

		case 'TOGGLE_CAT':
			return {
				...state,
				ui: {
					...state.ui,
					collapsedCats: { ...state.ui.collapsedCats, [ action.cat ]: ! state.ui.collapsedCats[ action.cat ] },
				},
			};

		case 'TOGGLE_FIELD_SECTION':
			return {
				...state,
				ui: {
					...state.ui,
					openFieldSections: {
						...state.ui.openFieldSections,
						[ action.section ]: ! state.ui.openFieldSections[ action.section ],
					},
				},
			};

		case 'TOGGLE_FORM_SECTION':
			return {
				...state,
				ui: {
					...state.ui,
					openFormSections: {
						...state.ui.openFormSections,
						[ action.section ]: ! state.ui.openFormSections[ action.section ],
					},
				},
			};

		case 'TOGGLE_FAVORITE': {
			const has = state.ui.favorites.includes( action.fieldType );
			const favorites = has
				? state.ui.favorites.filter( ( t ) => t !== action.fieldType )
				: [ ...state.ui.favorites, action.fieldType ];
			saveLocal( 'mailpilot_fb_favorites', favorites );
			return { ...state, ui: { ...state.ui, favorites } };
		}

		case 'ADD_RECENT': {
			const recent = [ action.fieldType, ...state.ui.recent.filter( ( t ) => t !== action.fieldType ) ].slice( 0, 5 );
			saveLocal( 'mailpilot_fb_recent', recent );
			return { ...state, ui: { ...state.ui, recent } };
		}

		case 'UNDO': {
			if ( ! state.ui.undoStack.length ) return state;
			const undoStack = [ ...state.ui.undoStack ];
			const prevFields = undoStack.pop();
			const redoStack = [ ...state.ui.redoStack, deepClone( state.fields ) ].slice( -UNDO_CAP );
			return { ...state, fields: prevFields, ui: { ...state.ui, undoStack, redoStack, saveState: 'dirty' } };
		}

		case 'REDO': {
			if ( ! state.ui.redoStack.length ) return state;
			const redoStack = [ ...state.ui.redoStack ];
			const nextFields = redoStack.pop();
			const undoStack = [ ...state.ui.undoStack, deepClone( state.fields ) ].slice( -UNDO_CAP );
			return { ...state, fields: nextFields, ui: { ...state.ui, undoStack, redoStack, saveState: 'dirty' } };
		}

		case 'SET_SAVE_STATE':
			return { ...state, ui: { ...state.ui, saveState: action.value } };

		case 'MARK_SAVED':
			return {
				...state,
				id: action.id,
				shortcode: action.shortcode,
				ui: { ...state.ui, saveState: 'saved', lastSavedAt: Date.now() },
			};

		case 'TOGGLE_STATUS_MENU':
			return { ...state, ui: { ...state.ui, statusMenuOpen: ! state.ui.statusMenuOpen, embedMenuOpen: false } };

		case 'TOGGLE_EMBED_MENU':
			return { ...state, ui: { ...state.ui, embedMenuOpen: ! state.ui.embedMenuOpen, statusMenuOpen: false } };

		case 'CLOSE_MENUS':
			return { ...state, ui: { ...state.ui, statusMenuOpen: false, embedMenuOpen: false } };

		case 'OPEN_PREVIEW':
			return { ...state, ui: { ...state.ui, previewOpen: true } };

		case 'CLOSE_PREVIEW':
			return { ...state, ui: { ...state.ui, previewOpen: false } };

		case 'SHOW_TOAST':
			return { ...state, ui: { ...state.ui, toast: { id: uid( 't' ), message: action.message } } };

		case 'HIDE_TOAST':
			return { ...state, ui: { ...state.ui, toast: null } };

		case 'ADD_LOGIC_RULE': {
			const nextFields = state.fields.map( ( f ) => {
				if ( f.id !== action.id ) return f;
				const rules = [ ...f.rules, { id: uid( 'r' ), field: '', operator: 'is', value: '' } ];
				return { ...f, rules };
			} );
			return withHistory( state, nextFields );
		}

		case 'UPDATE_LOGIC_RULE': {
			const nextFields = state.fields.map( ( f ) => {
				if ( f.id !== action.id ) return f;
				const rules = f.rules.map( ( r ) => ( r.id === action.ruleId ? { ...r, ...action.patch } : r ) );
				return { ...f, rules };
			} );
			return withHistory( state, nextFields );
		}

		case 'REMOVE_LOGIC_RULE': {
			const nextFields = state.fields.map( ( f ) => {
				if ( f.id !== action.id ) return f;
				return { ...f, rules: f.rules.filter( ( r ) => r.id !== action.ruleId ) };
			} );
			return withHistory( state, nextFields );
		}

		default:
			return state;
	}
}
