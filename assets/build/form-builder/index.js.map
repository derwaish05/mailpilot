/**
 * Left panel: search, Favorites / Recently used groups, and collapsible
 * Basic / Choice / Advanced categories built from `MailPilotBuilder.fieldTypes`.
 */
import { useMemo } from '@wordpress/element';
import { Search, Star, ChevronRight } from 'lucide-react';
import { CAT_TITLES, CAT_TINTS } from '../constants';
import { metaFor } from '../utils';
import { IconChip } from './Primitives';

function GripIcon() {
	return (
		<svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" stroke="none">
			<circle cx="9" cy="5" r="1.6" />
			<circle cx="9" cy="12" r="1.6" />
			<circle cx="9" cy="19" r="1.6" />
			<circle cx="15" cy="5" r="1.6" />
			<circle cx="15" cy="12" r="1.6" />
			<circle cx="15" cy="19" r="1.6" />
		</svg>
	);
}

function LibraryItem( { descriptor, isFavorite, onToggleFavorite, onPointerDown, onQuickAdd } ) {
	const meta = metaFor( descriptor.type );
	const tint = CAT_TINTS[ meta.cat ] || CAT_TINTS.basic;

	return (
		<div
			className="fb-library-item"
			role="button"
			tabIndex={ 0 }
			aria-label={ `Add ${ descriptor.label } field` }
			onPointerDown={ ( e ) => onPointerDown( e, descriptor ) }
			onKeyDown={ ( e ) => {
				if ( e.key === 'Enter' || e.key === ' ' ) {
					e.preventDefault();
					onQuickAdd( descriptor );
				}
			} }
		>
			<IconChip icon={ meta.icon } bg={ tint.bg } fg={ tint.fg } />
			<span className="fb-library-item-text">
				<span className="fb-library-item-label">{ descriptor.label }</span>
				<span className="fb-library-item-desc">{ meta.desc }</span>
			</span>
			<button
				type="button"
				className={ `fb-star-btn fb-reveal${ isFavorite ? ' is-fav' : '' }` }
				aria-label="Toggle favorite"
				onPointerDown={ ( e ) => e.stopPropagation() }
				onClick={ ( e ) => {
					e.stopPropagation();
					onToggleFavorite( descriptor.type );
				} }
			>
				<Star size={ 13 } fill={ isFavorite ? 'currentColor' : 'none' } strokeWidth={ 2 } />
			</button>
			<span className="fb-grip-static fb-reveal" aria-hidden="true">
				<GripIcon />
			</span>
		</div>
	);
}

function Category( { title, count, items, open, onToggle, favorites, onToggleFavorite, onPointerDown, onQuickAdd } ) {
	if ( ! items.length ) return null;
	return (
		<div>
			<button type="button" className={ `fb-library-cat-header${ open ? ' is-open' : '' }` } aria-expanded={ open } onClick={ onToggle }>
				<ChevronRight size={ 12 } strokeWidth={ 2.5 } />
				{ title }
				<span className="fb-library-cat-count">{ count }</span>
			</button>
			{ open && (
				<div className="fb-library-cat-items">
					{ items.map( ( d ) => (
						<LibraryItem
							key={ d.type }
							descriptor={ d }
							isFavorite={ favorites.includes( d.type ) }
							onToggleFavorite={ onToggleFavorite }
							onPointerDown={ onPointerDown }
							onQuickAdd={ onQuickAdd }
						/>
					) ) }
				</div>
			) }
		</div>
	);
}

export default function FieldLibrary( {
	fieldTypes,
	search,
	favorites,
	recent,
	collapsedCats,
	onSetSearch,
	onToggleCat,
	onToggleFavorite,
	onItemPointerDown,
	onQuickAdd,
} ) {
	const filtered = useMemo( () => {
		const q = search.trim().toLowerCase();
		if ( ! q ) return fieldTypes;
		return fieldTypes.filter( ( d ) => {
			const meta = metaFor( d.type );
			return d.label.toLowerCase().includes( q ) || ( meta.desc || '' ).toLowerCase().includes( q );
		} );
	}, [ fieldTypes, search ] );

	const byType = ( type ) => filtered.find( ( d ) => d.type === type );

	const favItems = favorites.map( byType ).filter( Boolean );
	const recentItems = recent.map( byType ).filter( Boolean );

	const grouped = { basic: [], choice: [], advanced: [] };
	filtered.forEach( ( d ) => {
		const cat = metaFor( d.type ).cat;
		( grouped[ cat ] || grouped.basic ).push( d );
	} );

	const noResults = filtered.length === 0;

	return (
		<aside className="fb-panel" style={ { width: 'var(--fb-left-width, 272px)' } }>
			<div className="fb-library-search-wrap">
				<div className="fb-library-search">
					<Search size={ 15 } strokeWidth={ 2 } />
					<input
						value={ search }
						onChange={ ( e ) => onSetSearch( e.target.value ) }
						placeholder="Search fields…"
						aria-label="Search fields"
					/>
				</div>
			</div>
			<div className="fb-library-body">
				{ favItems.length > 0 && (
					<Category
						title={ CAT_TITLES.favorites || 'Favorites' }
						count={ favItems.length }
						items={ favItems }
						open={ ! collapsedCats.favorites }
						onToggle={ () => onToggleCat( 'favorites' ) }
						favorites={ favorites }
						onToggleFavorite={ onToggleFavorite }
						onPointerDown={ onItemPointerDown }
						onQuickAdd={ onQuickAdd }
					/>
				) }
				{ recentItems.length > 0 && (
					<Category
						title="Recently used"
						count={ recentItems.length }
						items={ recentItems }
						open={ ! collapsedCats.recent }
						onToggle={ () => onToggleCat( 'recent' ) }
						favorites={ favorites }
						onToggleFavorite={ onToggleFavorite }
						onPointerDown={ onItemPointerDown }
						onQuickAdd={ onQuickAdd }
					/>
				) }
				{ [ 'basic', 'choice', 'advanced' ].map( ( cat ) => (
					<Category
						key={ cat }
						title={ CAT_TITLES[ cat ] }
						count={ grouped[ cat ].length }
						items={ grouped[ cat ] }
						open={ ! collapsedCats[ cat ] }
						onToggle={ () => onToggleCat( cat ) }
						favorites={ favorites }
						onToggleFavorite={ onToggleFavorite }
						onPointerDown={ onItemPointerDown }
						onQuickAdd={ onQuickAdd }
					/>
				) ) }
				{ noResults && <div className="fb-no-results">No fields match “{ search }”</div> }
			</div>
		</aside>
	);
}
