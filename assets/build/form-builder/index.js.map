/**
 * Canvas region: dot-grid surface, centered column with editable form title
 * + field count, the field-card list (with drop-line insertion indicator),
 * and the empty state.
 */
import { Fragment } from '@wordpress/element';
import { Plus } from 'lucide-react';
import FieldCard from './FieldCard';
import { DEVICE_WIDTHS } from '../constants';

function DropLine( { active } ) {
	return (
		<div className={ `fb-drop-line${ active ? ' is-active' : '' }` } style={ { flexBasis: '100%', width: '100%' } }>
			<span className="fb-drop-line-dot" />
			<span className="fb-drop-line-bar" />
		</div>
	);
}

export default function Canvas( {
	canvasRef,
	cardsRef,
	fields,
	fieldTypes,
	selectedId,
	device,
	title,
	onSetTitle,
	dragState,
	onSelectField,
	onDuplicateField,
	onDeleteField,
	onGripPointerDown,
	onAddFirstField,
} ) {
	const isEmpty = fields.length === 0;
	const maxWidth = DEVICE_WIDTHS[ device ] || DEVICE_WIDTHS.desktop;
	const dropIndex = dragState && dragState.started ? dragState.dropIndex : null;
	const draggingFieldId = dragState && dragState.kind === 'reorder' ? dragState.data.fieldId : null;

	return (
		<main className="fb-canvas" ref={ canvasRef }>
			<div className="fb-canvas-inner">
				<div className="fb-canvas-col" style={ { maxWidth } } ref={ cardsRef }>
					<div className="fb-form-header">
						<input
							className="fb-form-title-input"
							value={ title }
							onChange={ ( e ) => onSetTitle( e.target.value ) }
							aria-label="Form name"
						/>
						<div className="fb-field-count">{ fields.length } field{ fields.length === 1 ? '' : 's' }</div>
					</div>

					{ isEmpty && (
						<div className={ `fb-empty-state${ dragState && ! draggingFieldId ? ' is-drag-over' : '' }` }>
							<div className="fb-empty-illustration">
								<div style={ { position: 'absolute', left: 10, top: 14, width: 100, height: 24, borderRadius: 8, background: '#fff', border: '1px solid #E7E9EE', boxShadow: '0 2px 6px rgba(16,24,40,.06)' } } />
								<div style={ { position: 'absolute', left: 0, top: 46, width: 100, height: 24, borderRadius: 8, background: '#fff', border: '1px solid #E7E9EE', boxShadow: '0 4px 10px rgba(16,24,40,.08)', transform: 'rotate(-2deg)' } } />
								<div style={ { position: 'absolute', right: 0, top: 34, width: 34, height: 34, borderRadius: 10, background: 'var(--fb-accent)', display: 'flex', alignItems: 'center', justifyContent: 'center', boxShadow: '0 6px 14px rgba(37,99,235,.35)' } }>
									<Plus size={ 18 } color="#fff" strokeWidth={ 2.5 } />
								</div>
							</div>
							<div className="fb-empty-title">Drag your first field here</div>
							<div className="fb-empty-desc">Pick anything from the library on the left, or start with the basics.</div>
							<button type="button" className="fb-btn-primary" onClick={ onAddFirstField }>
								<Plus size={ 15 } strokeWidth={ 2.5 } />
								Add Field
							</button>
						</div>
					) }

					{ ! isEmpty && (
						<div className="fb-cards-row">
							<DropLine active={ dropIndex === 0 } />
							{ fields.map( ( field, index ) => (
								<Fragment key={ field.id }>
									<div className={ `fb-card-wrap width-${ field.width || 'full' }` }>
										<FieldCard
											field={ field }
											fieldTypes={ fieldTypes }
											selected={ field.id === selectedId }
											dragging={ field.id === draggingFieldId }
											onSelect={ () => onSelectField( field.id ) }
											onDuplicate={ () => onDuplicateField( field.id ) }
											onDelete={ () => onDeleteField( field.id ) }
											onGripPointerDown={ ( e ) => onGripPointerDown( e, field.id, index ) }
										/>
									</div>
									<DropLine active={ dropIndex === index + 1 } />
								</Fragment>
							) ) }
						</div>
					) }

					{ ! isEmpty && (
						<button type="button" className="fb-add-field-inline" onClick={ onAddFirstField }>
							<Plus size={ 14 } strokeWidth={ 2.5 } />
							Add field
						</button>
					) }
				</div>
			</div>
		</main>
	);
}
