/**
 * Preview modal — a client-side rendering of the current field state using
 * the same per-type mock data as the canvas cards (no live-render endpoint
 * exists on the backend, so this is an accepted simplification per the
 * build brief).
 */
import { X } from 'lucide-react';
import { useClickOutside } from './Primitives';
import { useRef } from '@wordpress/element';
import { previewKind, previewText } from '../utils';

const MODAL_WIDTHS = { desktop: 720, tablet: 560, mobile: 400 };
const DEVICE_LABELS = { desktop: 'Desktop', tablet: 'Tablet', mobile: 'Mobile' };

function PreviewField( { field } ) {
	const kind = previewKind( field );
	const text = previewText( field );
	const opts = ( field.options || [] ).map( ( o ) => o.label || o.value );

	return (
		<div>
			<div className="fb-preview-field-label">
				{ field.label }
				{ field.required && <span className="fb-preview-required"> *</span> }
			</div>
			{ kind === 'nameSplit' && (
				<div className="fb-preview-grid-2">
					<input className="fb-preview-input" placeholder="First name" readOnly />
					<input className="fb-preview-input" placeholder="Last name" readOnly />
				</div>
			) }
			{ kind === 'textarea' && <textarea className="fb-preview-textarea" placeholder={ text } rows={ 3 } readOnly /> }
			{ kind === 'select' && (
				<select className="fb-preview-select" disabled>
					<option>{ text }</option>
				</select>
			) }
			{ kind === 'radio' && (
				<div className="fb-preview-option-list">
					{ ( opts.length ? opts : [ 'Option 1', 'Option 2' ] ).map( ( o, i ) => (
						<label className="fb-preview-option-label" key={ i }>
							<input type="radio" name={ field.id } disabled />
							{ o }
						</label>
					) ) }
				</div>
			) }
			{ kind === 'checkbox' && (
				<div className="fb-preview-option-list">
					{ ( opts.length ? opts : [ 'Option 1', 'Option 2' ] ).map( ( o, i ) => (
						<label className="fb-preview-option-label" key={ i }>
							<input type="checkbox" disabled />
							{ o }
						</label>
					) ) }
				</div>
			) }
			{ kind === 'hidden' && null }
			{ kind === 'input' && <input className="fb-preview-input" placeholder={ text } readOnly /> }
		</div>
	);
}

export default function PreviewModal( { open, onClose, title, fields, device, buttonText } ) {
	const ref = useRef( null );
	useClickOutside( ref, onClose, open );

	if ( ! open ) return null;

	const maxWidth = MODAL_WIDTHS[ device ] || MODAL_WIDTHS.desktop;
	const visibleFields = fields.filter( ( f ) => previewKind( f ) !== 'hidden' );

	return (
		<div className="fb-modal-overlay">
			<div ref={ ref } role="dialog" aria-label="Form preview" className="fb-modal" style={ { maxWidth } }>
				<div className="fb-modal-header">
					<span className="fb-modal-title">Preview · { DEVICE_LABELS[ device ] || 'Desktop' }</span>
					<button type="button" className="fb-icon-btn" aria-label="Close preview" onClick={ onClose }>
						<X size={ 16 } />
					</button>
				</div>
				<div className="fb-modal-body">
					<div className="fb-preview-form-title">{ title }</div>
					<div className="fb-preview-fields">
						{ visibleFields.map( ( f ) => <PreviewField field={ f } key={ f.id } /> ) }
						<button type="button" className="fb-preview-submit">{ buttonText || 'Subscribe' }</button>
					</div>
				</div>
			</div>
		</div>
	);
}
