/**
 * Top toolbar (56px): back link, inline-editable name + save status,
 * undo/redo, responsive-preview segmented control, status pill, Embed
 * popover, Preview, and the primary Save button.
 */
import { useRef } from '@wordpress/element';
import { ArrowLeft, Undo2, Redo2, Monitor, Tablet, Smartphone, ChevronDown, Check, Code2, Copy, Eye } from 'lucide-react';
import { Segmented, useClickOutside } from './Primitives';

const DEVICE_OPTS = [
	{ value: 'desktop', label: 'Desktop', icon: Monitor },
	{ value: 'tablet', label: 'Tablet', icon: Tablet },
	{ value: 'mobile', label: 'Mobile', icon: Smartphone },
];

function DeviceSegmented( { value, onChange } ) {
	return (
		<div role="group" aria-label="Responsive preview" className="fb-segmented">
			{ DEVICE_OPTS.map( ( o ) => (
				<button
					key={ o.value }
					type="button"
					aria-label={ o.label }
					title={ o.label }
					className={ `fb-segmented-option${ value === o.value ? ' is-active' : '' }` }
					onClick={ () => onChange( o.value ) }
					style={ { flex: '0 0 auto', padding: '6px 9px' } }
				>
					<o.icon size={ 14 } />
				</button>
			) ) }
		</div>
	);
}

export default function Toolbar( {
	title,
	onSetTitle,
	saveDotClass,
	saveLabel,
	onUndo,
	onRedo,
	canUndo,
	canRedo,
	device,
	onSetDevice,
	status,
	statusMenuOpen,
	onToggleStatusMenu,
	onSetStatus,
	onCloseMenus,
	embedMenuOpen,
	onToggleEmbedMenu,
	displayTypes,
	displayType,
	onSetDisplayType,
	shortcode,
	onCopyShortcode,
	onOpenPreview,
	onSave,
	saving,
	listUrl,
} ) {
	const statusRef = useRef( null );
	const embedRef = useRef( null );
	useClickOutside( statusRef, onCloseMenus, statusMenuOpen );
	useClickOutside( embedRef, onCloseMenus, embedMenuOpen );

	return (
		<header className="fb-toolbar">
			<a className="fb-back-btn" href={ listUrl } aria-label="Back to Forms">
				<ArrowLeft size={ 16 } />
				Forms
			</a>

			<div className="fb-toolbar-divider" />

			<div style={ { display: 'flex', alignItems: 'center', gap: 10, minWidth: 0 } }>
				<input
					className="fb-name-input"
					value={ title }
					onChange={ ( e ) => onSetTitle( e.target.value ) }
					aria-label="Form name"
				/>
				<div className="fb-save-status">
					<span className={ `fb-save-dot ${ saveDotClass }` } />
					{ saveLabel }
				</div>
			</div>

			<div className="fb-spacer" />

			<div style={ { display: 'flex', alignItems: 'center', gap: 2 } }>
				<button type="button" className="fb-icon-btn" aria-label="Undo" title="Undo (⌘Z)" onClick={ onUndo } disabled={ ! canUndo }>
					<Undo2 size={ 16 } />
				</button>
				<button type="button" className="fb-icon-btn" aria-label="Redo" title="Redo (⇧⌘Z)" onClick={ onRedo } disabled={ ! canRedo }>
					<Redo2 size={ 16 } />
				</button>
			</div>

			<div className="fb-toolbar-divider" />

			<DeviceSegmented value={ device } onChange={ onSetDevice } />

			<div className="fb-toolbar-divider" />

			<div style={ { position: 'relative' } } ref={ statusRef }>
				<button type="button" className="fb-status-pill" aria-haspopup="menu" onClick={ onToggleStatusMenu }>
					<span className={ `fb-status-dot status-${ status }` } />
					{ status === 'published' ? 'Published' : 'Draft' }
					<ChevronDown size={ 13 } color="#98A2B3" />
				</button>
				{ statusMenuOpen && (
					<div role="menu" className="fb-menu" style={ { top: 'calc(100% + 6px)', right: 0, width: 180 } }>
						{ [ 'draft', 'published' ].map( ( s ) => (
							<button key={ s } role="menuitem" type="button" className="fb-menu-item" onClick={ () => onSetStatus( s ) }>
								<span className={ `fb-status-dot status-${ s }` } />
								{ s === 'published' ? 'Published' : 'Draft' }
								{ status === s && <Check size={ 14 } className="fb-check" /> }
							</button>
						) ) }
					</div>
				) }
			</div>

			<div style={ { position: 'relative' } } ref={ embedRef }>
				<button type="button" className="fb-btn-secondary" aria-haspopup="dialog" onClick={ onToggleEmbedMenu }>
					<Code2 size={ 15 } />
					Embed
				</button>
				{ embedMenuOpen && (
					<div role="dialog" aria-label="Embed form" className="fb-menu" style={ { top: 'calc(100% + 6px)', right: 0, width: 280, padding: 14 } }>
						<div className="fb-popover-title">Display as</div>
						<div style={ { display: 'flex', flexDirection: 'column', gap: 2, marginBottom: 12 } }>
							{ ( displayTypes || [] ).map( ( o ) => (
								<button key={ o.value } type="button" className="fb-menu-item" onClick={ () => onSetDisplayType( o.value ) }>
									{ o.label }
									{ displayType === o.value && <Check size={ 14 } className="fb-check" /> }
								</button>
							) ) }
						</div>
						<div className="fb-popover-title">Shortcode</div>
						<button type="button" className="fb-shortcode-btn" title="Copy shortcode" onClick={ onCopyShortcode }>
							{ shortcode || '[mailpilot_form id="0"]' }
							<Copy size={ 14 } color="#98A2B3" />
						</button>
					</div>
				) }
			</div>

			<button type="button" className="fb-btn-secondary" onClick={ onOpenPreview }>
				<Eye size={ 15 } />
				Preview
			</button>

			<button type="button" className="fb-btn-primary" onClick={ onSave } disabled={ saving }>
				{ saving ? 'Saving…' : 'Save' }
			</button>
		</header>
	);
}
